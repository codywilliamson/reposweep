---
// skeleton placeholder while repos load (used by dashboard)
---

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
  <div class="mb-8">
    <div class="h-8 w-48 animate-pulse rounded-lg bg-bg-secondary" />
    <div class="mt-2 h-4 w-32 animate-pulse rounded bg-bg-secondary" />
  </div>

  <!-- filter bar skeleton -->
  <div class="glass rounded-xl p-4">
    <div class="flex flex-wrap items-center gap-3">
      <div class="h-10 flex-1 min-w-[200px] animate-pulse rounded-lg bg-bg-primary" />
      <div class="h-10 w-36 animate-pulse rounded-lg bg-bg-primary" />
      <div class="h-10 w-36 animate-pulse rounded-lg bg-bg-primary" />
      <div class="h-10 w-28 animate-pulse rounded-lg bg-bg-primary" />
    </div>
  </div>

  <!-- card grid skeleton -->
  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {Array.from({ length: 9 }).map(() => (
      <div class="glass rounded-xl p-4">
        <div class="flex items-start gap-3">
          <div class="mt-0.5 h-4 w-4 animate-pulse rounded bg-bg-primary" />
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <div class="h-4 w-32 animate-pulse rounded bg-bg-primary" />
              <div class="h-5 w-14 animate-pulse rounded-full bg-bg-primary" />
            </div>
            <div class="mt-2 h-3 w-full animate-pulse rounded bg-bg-primary" />
            <div class="mt-3 flex gap-3">
              <div class="h-3 w-16 animate-pulse rounded bg-bg-primary" />
              <div class="h-3 w-20 animate-pulse rounded bg-bg-primary" />
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
