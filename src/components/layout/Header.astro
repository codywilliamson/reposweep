---
import ThemeToggle from "@/components/ui/ThemeToggle.vue";
import UserMenu from "@/components/ui/UserMenu.vue";
import type { GitHubSession } from "@/lib/types";

interface Props {
  session?: GitHubSession;
}

const { session } = Astro.props;
---

<header class="sticky top-0 z-50 glass">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-lg font-bold">
      <svg class="h-6 w-6 text-accent-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
      </svg>
      <span class="gradient-text">RepoSweep</span>
    </a>

    <div class="flex items-center gap-3">
      <ThemeToggle client:load />
      {session ? (
        <UserMenu
          client:load
          login={session.login}
          avatarUrl={session.avatarUrl}
          name={session.name ?? session.login}
        />
      ) : (
        <a
          href="/api/auth/login"
          class="rounded-lg bg-accent-purple px-4 py-2 text-sm font-medium text-bg-primary transition-opacity hover:opacity-90"
        >
          Sign in
        </a>
      )}
    </div>
  </div>
</header>
