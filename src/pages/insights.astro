---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchCommitInsights, fetchUserRepos } from "@/lib/github";
import { getRuntimeEnv } from "@/lib/storage";
import type { CommitInsights, CommitInsightsFilters, CommitTrendDirection, InsightsArchived, InsightsSort, InsightsVisibility } from "@/lib/types";

const session = Astro.locals.session!;
const runtimeEnv = getRuntimeEnv(Astro.locals);
const searchParams = Astro.url.searchParams;

const dayOptions = [7, 30, 90, 180];
const limitOptions = [10, 25, 50, 100];
const visibilityOptions: { value: InsightsVisibility; label: string }[] = [
  { value: "all", label: "All repos" },
  { value: "public", label: "Public only" },
  { value: "private", label: "Private only" },
];
const archivedOptions: { value: InsightsArchived; label: string }[] = [
  { value: "active", label: "Active only" },
  { value: "all", label: "Include archived" },
  { value: "archived", label: "Archived only" },
];
const sortOptions: { value: InsightsSort; label: string }[] = [
  { value: "total", label: "Total commits" },
  { value: "last7", label: "Last 7 days" },
  { value: "last30", label: "Last 30 days" },
  { value: "avgWeekly", label: "Average weekly" },
];

const filters: CommitInsightsFilters = {
  days: parseNumber(searchParams.get("days"), 90, dayOptions),
  visibility: parseEnum(searchParams.get("visibility"), ["all", "public", "private"], "all"),
  archived: parseEnum(searchParams.get("archived"), ["active", "all", "archived"], "active"),
  search: (searchParams.get("search") ?? "").trim(),
  limit: parseNumber(searchParams.get("limit"), 25, limitOptions),
  sort: parseEnum(searchParams.get("sort"), ["total", "last7", "last30", "avgWeekly"], "total"),
};

let error = "";
let insights: CommitInsights | null = null;

try {
  const repos = await fetchUserRepos(session.accessToken);
  insights = await fetchCommitInsights(session.accessToken, repos, session.login, filters, runtimeEnv);
} catch (e: any) {
  error = e.message ?? "Failed to load commit insights";
}

const numberFormatter = new Intl.NumberFormat("en-US");
const maxWeeklyTotal = insights ? Math.max(...insights.weeklyTotals.map((week) => week.total), 1) : 1;
const maxRepoCommits = insights ? Math.max(...insights.repoSpread.map((repo) => repo.commits), 1) : 1;
const maxSparkline = insights ? Math.max(...insights.repoSpread.flatMap((repo) => repo.sparkline), 1) : 1;
const weeklyChart = insights ? buildWeeklyChart(insights.weeklyTotals) : null;
const chartLabels = insights ? buildWeeklyLabels(insights.weeklyTotals) : [];

function parseNumber(value: string | null, fallback: number, allowed: number[]) {
  const parsed = Number(value);
  return allowed.includes(parsed) ? parsed : fallback;
}

function parseEnum<T extends string>(value: string | null, allowed: T[], fallback: T): T {
  return value && allowed.includes(value as T) ? (value as T) : fallback;
}

function formatNumber(value: number) {
  return numberFormatter.format(Math.round(value * 10) / 10);
}

function formatPercent(value: number) {
  const sign = value > 0 ? "+" : "";
  return `${sign}${formatNumber(value)}%`;
}

function formatDate(value: string) {
  return new Date(value).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
  });
}

function trendLabel(direction: CommitTrendDirection, delta: number) {
  if (direction === "steady") return "Steady";
  return `${direction === "up" ? "Up" : "Down"} ${formatPercent(delta)}`;
}

function trendClasses(direction: CommitTrendDirection) {
  switch (direction) {
    case "up":
      return "bg-accent-green/15 text-accent-green";
    case "down":
      return "bg-accent-red/15 text-accent-red";
    default:
      return "bg-accent-cyan/15 text-accent-cyan";
  }
}

function buildWeeklyChart(weeks: CommitInsights["weeklyTotals"]) {
  if (weeks.length === 0) return null;

  const width = 960;
  const height = 240;
  const left = 16;
  const right = 16;
  const top = 16;
  const bottom = 16;
  const innerWidth = width - left - right;
  const innerHeight = height - top - bottom;
  const maxValue = Math.max(...weeks.map((week) => week.total), 1);
  const denominator = Math.max(weeks.length - 1, 1);

  const points = weeks.map((week, index) => {
    const x = left + (innerWidth * index) / denominator;
    const y = top + innerHeight - (week.total / maxValue) * innerHeight;
    return `${x},${y}`;
  });

  const area = [
    `${left},${height - bottom}`,
    ...points,
    `${left + innerWidth},${height - bottom}`,
  ].join(" ");

  return {
    width,
    height,
    linePoints: points.join(" "),
    areaPoints: area,
  };
}

function buildWeeklyLabels(weeks: CommitInsights["weeklyTotals"]) {
  if (weeks.length === 0) return [];
  const picks = Array.from(new Set([0, Math.floor((weeks.length - 1) / 2), weeks.length - 1]));
  return picks.map((index) => ({
    index,
    label: formatDate(weeks[index].weekStart),
  }));
}
---

<BaseLayout title="Insights">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
    <div class="animate-in mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm uppercase tracking-[0.24em] text-accent-cyan">Commit Analytics</p>
        <h1 class="mt-2 text-3xl font-bold sm:text-4xl">Repo velocity, spread, and trendlines</h1>
        {insights && (
          <p class="mt-2 max-w-3xl text-sm text-fg-muted">
            Using direct commit history on each repo's default branch for the selected window, so the totals line up
            much better with current activity.
          </p>
        )}
      </div>

      {insights && (
        <div class="rounded-2xl border border-border-default bg-bg-secondary/80 px-4 py-3 text-sm text-fg-muted">
          Refreshed {new Date(insights.generatedAt).toLocaleString("en-US", {
            month: "short",
            day: "numeric",
            hour: "numeric",
            minute: "2-digit",
          })}
        </div>
      )}
    </div>

    <section class="glass rounded-2xl p-5">
      <form method="GET" class="grid gap-4 lg:grid-cols-[1.5fr_repeat(5,minmax(0,1fr))]">
        <label class="block">
          <span class="mb-1.5 block text-xs font-medium uppercase tracking-[0.2em] text-fg-muted">Search Repos</span>
          <input
            type="text"
            name="search"
            value={filters.search}
            placeholder="repo name..."
            class="w-full rounded-xl border border-border-default bg-bg-primary px-3 py-2.5 text-sm text-fg-primary outline-none transition-colors focus:border-accent-cyan"
          />
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-medium uppercase tracking-[0.2em] text-fg-muted">Window</span>
          <select name="days" class="w-full rounded-xl border border-border-default bg-bg-primary px-3 py-2.5 text-sm text-fg-primary outline-none transition-colors focus:border-accent-cyan">
            {dayOptions.map((option) => (
              <option value={option} selected={filters.days === option}>{option} days</option>
            ))}
          </select>
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-medium uppercase tracking-[0.2em] text-fg-muted">Visibility</span>
          <select name="visibility" class="w-full rounded-xl border border-border-default bg-bg-primary px-3 py-2.5 text-sm text-fg-primary outline-none transition-colors focus:border-accent-cyan">
            {visibilityOptions.map((option) => (
              <option value={option.value} selected={filters.visibility === option.value}>{option.label}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-medium uppercase tracking-[0.2em] text-fg-muted">Archived</span>
          <select name="archived" class="w-full rounded-xl border border-border-default bg-bg-primary px-3 py-2.5 text-sm text-fg-primary outline-none transition-colors focus:border-accent-cyan">
            {archivedOptions.map((option) => (
              <option value={option.value} selected={filters.archived === option.value}>{option.label}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-medium uppercase tracking-[0.2em] text-fg-muted">Repo Coverage</span>
          <select name="limit" class="w-full rounded-xl border border-border-default bg-bg-primary px-3 py-2.5 text-sm text-fg-primary outline-none transition-colors focus:border-accent-cyan">
            {limitOptions.map((option) => (
              <option value={option} selected={filters.limit === option}>Top {option}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <span class="mb-1.5 block text-xs font-medium uppercase tracking-[0.2em] text-fg-muted">Sort Repos</span>
          <select name="sort" class="w-full rounded-xl border border-border-default bg-bg-primary px-3 py-2.5 text-sm text-fg-primary outline-none transition-colors focus:border-accent-cyan">
            {sortOptions.map((option) => (
              <option value={option.value} selected={filters.sort === option.value}>{option.label}</option>
            ))}
          </select>
        </label>

        <div class="flex items-end gap-3 lg:col-span-full">
          <button
            type="submit"
            class="rounded-xl bg-accent-purple px-5 py-2.5 text-sm font-medium text-bg-primary transition-opacity hover:opacity-90"
          >
            Apply filters
          </button>
          <a
            href="/insights"
            class="rounded-xl border border-border-default px-5 py-2.5 text-sm font-medium text-fg-secondary transition-colors hover:border-accent-cyan hover:text-accent-cyan"
          >
            Reset
          </a>
        </div>
      </form>
    </section>

    {error ? (
      <div class="glass mt-8 rounded-2xl p-8 text-center">
        <p class="text-accent-red">{error}</p>
        <p class="mt-2 text-sm text-fg-muted">
          Try narrowing the repo search or reducing repo coverage if GitHub takes too long to answer.
        </p>
      </div>
    ) : insights ? (
      <>
        <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-fg-muted">
          <span class="rounded-full bg-bg-secondary px-3 py-1.5">
            {formatNumber(insights.activeRepoCount)} active repos found
          </span>
          <span class="rounded-full bg-bg-secondary px-3 py-1.5">
            {formatNumber(insights.analyzedRepoCount)} of {formatNumber(insights.matchingRepoCount)} matching repos analyzed
          </span>
          {insights.matchingRepoCount > insights.analyzedRepoCount && (
            <span class="rounded-full bg-accent-yellow/15 px-3 py-1.5 text-accent-yellow">
              Increase repo coverage to widen totals
            </span>
          )}
        </div>

        <section class="stagger mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
          <div class="glass hover-lift rounded-2xl p-5">
            <p class="text-sm text-fg-muted">Commits ({insights.days}d)</p>
            <p class="mt-3 text-3xl font-semibold">{formatNumber(insights.totalCommits)}</p>
            <p class="mt-2 text-sm text-fg-muted">{formatNumber(insights.commitsLast30Days)} in the last 30 days</p>
          </div>
          <div class="glass hover-lift rounded-2xl p-5">
            <p class="text-sm text-fg-muted">Weekly Velocity</p>
            <p class="mt-3 text-3xl font-semibold">{formatNumber(insights.averageWeeklyCommits)}</p>
            <p class="mt-2 text-sm text-fg-muted">{formatNumber(insights.averageDailyCommits)} commits per day</p>
          </div>
          <div class="glass hover-lift rounded-2xl p-5">
            <p class="text-sm text-fg-muted">7-Day Trend</p>
            <p class="mt-3 text-3xl font-semibold">{formatNumber(insights.commitsLast7Days)}</p>
            <p class:list={["mt-2 inline-flex rounded-full px-2.5 py-1 text-xs font-medium", trendClasses(insights.trendDirection)]}>
              {trendLabel(insights.trendDirection, insights.trendDelta)}
            </p>
          </div>
          <div class="glass hover-lift rounded-2xl p-5">
            <p class="text-sm text-fg-muted">Active Repos</p>
            <p class="mt-3 text-3xl font-semibold">{formatNumber(insights.activeRepoCount)}</p>
            <p class="mt-2 text-sm text-fg-muted">{formatNumber(insights.averageCommitsPerActiveRepo)} commits per active repo</p>
          </div>
          <div class="glass hover-lift rounded-2xl p-5">
            <p class="text-sm text-fg-muted">Top Repo Share</p>
            <p class="mt-3 text-3xl font-semibold">{formatNumber(insights.topRepoShare)}%</p>
            <p class="mt-2 text-sm text-fg-muted">Share of commits from your busiest repo</p>
          </div>
        </section>

        <section class="mt-8 grid gap-6 xl:grid-cols-[1.5fr_1fr]">
          <div class="glass rounded-2xl p-6">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <h2 class="text-xl font-semibold">Weekly Commit Trend</h2>
                <p class="mt-1 text-sm text-fg-muted">Actual commit counts grouped by week for the selected filters.</p>
              </div>
              <div class="rounded-full bg-bg-primary px-3 py-1 text-xs text-fg-muted">
                {insights.weeklyTotals.length} weekly buckets
              </div>
            </div>

            {weeklyChart ? (
              <div class="mt-6 rounded-2xl border border-border-default bg-bg-primary/70 p-4">
                <svg viewBox={`0 0 ${weeklyChart.width} ${weeklyChart.height}`} class="h-64 w-full" role="img" aria-label="Weekly commit trend chart">
                  <defs>
                    <linearGradient id="weekly-area" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="var(--ss-accent-cyan)" stop-opacity="0.45" />
                      <stop offset="100%" stop-color="var(--ss-accent-purple)" stop-opacity="0.04" />
                    </linearGradient>
                  </defs>
                  <path d={`M ${weeklyChart.areaPoints.replaceAll(" ", " L ")}`} fill="url(#weekly-area)" />
                  <polyline
                    points={weeklyChart.linePoints}
                    fill="none"
                    stroke="var(--ss-accent-purple)"
                    stroke-width="4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  {insights.weeklyTotals.map((week, index) => {
                    const x = 16 + ((weeklyChart.width - 32) * index) / Math.max(insights.weeklyTotals.length - 1, 1);
                    const y = 16 + (1 - week.total / maxWeeklyTotal) * (weeklyChart.height - 32);
                    return (
                      <circle
                        cx={x}
                        cy={y}
                        r="4"
                        fill="var(--ss-accent-cyan)"
                      >
                        <title>{`${week.total} commits starting ${formatDate(week.weekStart)}`}</title>
                      </circle>
                    );
                  })}
                </svg>

                <div class="mt-3 flex items-center justify-between text-xs text-fg-muted">
                  {chartLabels.map((label) => (
                    <span>{label.label}</span>
                  ))}
                </div>
              </div>
            ) : (
              <div class="mt-6 rounded-2xl border border-border-default bg-bg-primary/70 p-8 text-center text-sm text-fg-muted">
                No weekly commits found for the selected filters.
              </div>
            )}
          </div>

          <div class="glass rounded-2xl p-6">
            <h2 class="text-xl font-semibold">Readout</h2>
            <div class="mt-5 space-y-4 text-sm text-fg-secondary">
              <div class="rounded-2xl border border-border-default bg-bg-primary/70 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-fg-muted">Current Pace</p>
                <p class="mt-2 text-lg font-semibold text-fg-primary">
                  {formatNumber(insights.commitsLast7Days)} commits in the last 7 days
                </p>
                <p class="mt-1 text-fg-muted">
                  Compared with {formatNumber(insights.previous7DayCommits)} in the prior 7-day stretch.
                </p>
              </div>
              <div class="rounded-2xl border border-border-default bg-bg-primary/70 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-fg-muted">Coverage</p>
                <p class="mt-2 text-lg font-semibold text-fg-primary">
                  {formatNumber(insights.analyzedRepoCount)} repos analyzed
                </p>
                <p class="mt-1 text-fg-muted">
                  Out of {formatNumber(insights.matchingRepoCount)} matching repos and {formatNumber(insights.totalRepoCount)} total repos.
                </p>
              </div>
              <div class="rounded-2xl border border-border-default bg-bg-primary/70 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-fg-muted">Concentration</p>
                <p class="mt-2 text-lg font-semibold text-fg-primary">
                  {formatNumber(insights.topRepoShare)}% from your busiest repo
                </p>
                <p class="mt-1 text-fg-muted">
                  Helpful for spotting whether the work is concentrated or spread out.
                </p>
              </div>
            </div>
          </div>
        </section>

        <section class="mt-8 glass rounded-2xl p-6">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 class="text-xl font-semibold">Commit Spread by Repo</h2>
              <p class="mt-1 text-sm text-fg-muted">
                Sorted by {sortOptions.find((option) => option.value === filters.sort)?.label.toLowerCase()} for the current filters.
              </p>
            </div>
            <p class="text-sm text-fg-muted">Showing {insights.repoSpread.length} repos</p>
          </div>

          <div class="mt-6 overflow-x-auto">
            <table class="min-w-full border-separate border-spacing-y-3">
              <thead>
                <tr class="text-left text-xs uppercase tracking-[0.2em] text-fg-muted">
                  <th class="pb-1 pr-4">Repository</th>
                  <th class="pb-1 pr-4">Spread</th>
                  <th class="pb-1 pr-4">Total</th>
                  <th class="pb-1 pr-4">30d</th>
                  <th class="pb-1 pr-4">7d</th>
                  <th class="pb-1 pr-4">Avg/Wk</th>
                  <th class="pb-1">Trend</th>
                </tr>
              </thead>
              <tbody>
                {insights.repoSpread.map((repo) => (
                  <tr class="rounded-2xl bg-bg-secondary/70">
                    <td class="rounded-l-2xl px-4 py-4 align-middle">
                      <a href={repo.htmlUrl} target="_blank" rel="noopener" class="font-medium text-fg-primary transition-colors hover:text-accent-cyan">
                        {repo.fullName}
                      </a>
                    </td>
                    <td class="px-4 py-4 align-middle">
                      <div class="flex min-w-[180px] items-center gap-3">
                        <div class="h-2 flex-1 overflow-hidden rounded-full bg-bg-primary">
                          <div
                            class="h-full rounded-full bg-gradient-to-r from-accent-cyan to-accent-purple"
                            style={`width: ${(repo.commits / maxRepoCommits) * 100}%;`}
                          />
                        </div>
                        <span class="text-xs text-fg-muted">
                          {insights.totalCommits > 0 ? formatNumber((repo.commits / insights.totalCommits) * 100) : "0"}%
                        </span>
                      </div>
                    </td>
                    <td class="px-4 py-4 align-middle font-medium text-fg-primary">{formatNumber(repo.commits)}</td>
                    <td class="px-4 py-4 align-middle text-fg-secondary">{formatNumber(repo.commitsLast30Days)}</td>
                    <td class="px-4 py-4 align-middle text-fg-secondary">{formatNumber(repo.commitsLast7Days)}</td>
                    <td class="px-4 py-4 align-middle text-fg-secondary">{formatNumber(repo.averageWeeklyCommits)}</td>
                    <td class="rounded-r-2xl px-4 py-4 align-middle">
                      <div class="flex items-center gap-3">
                        <div class="flex h-9 items-end gap-1">
                          {repo.sparkline.map((value) => (
                            <span
                              class="w-2 rounded-t-full bg-accent-purple/70"
                              style={`height: ${Math.max((value / maxSparkline) * 100, value > 0 ? 14 : 4)}%;`}
                              title={`${value} commits`}
                            />
                          ))}
                        </div>
                        <span class:list={["rounded-full px-2.5 py-1 text-xs font-medium", trendClasses(repo.trendDirection)]}>
                          {trendLabel(repo.trendDirection, repo.trendDelta)}
                        </span>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </>
    ) : null}
  </div>
</BaseLayout>
