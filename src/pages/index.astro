---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSessionFromCookies } from "@/lib/auth";
import { getRuntimeEnv } from "@/lib/storage";

const session = await getSessionFromCookies(Astro.cookies, getRuntimeEnv(Astro.locals));
if (session) return Astro.redirect("/dashboard");

const features = [
  {
    title: "Toggle Visibility",
    description: "Switch repos between public and private with one click.",
    icon: `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`,
  },
  {
    title: "Bulk Actions",
    description: "Select multiple repos and act on them all at once.",
    icon: `<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>`,
  },
  {
    title: "Archive & Delete",
    description: "Clean house — archive stale repos or delete them for good.",
    icon: `<polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>`,
  },
  {
    title: "Rename & Describe",
    description: "Update repo names and descriptions without leaving the dashboard.",
    icon: `<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>`,
  },
  {
    title: "Filter & Sort",
    description: "Search, filter by language or visibility, and sort by any field.",
    icon: `<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>`,
  },
  {
    title: "Real-time Status",
    description: "Watch operations complete live with a built-in status queue.",
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
];
---

<BaseLayout title="RepoSweep">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <!-- hero -->
    <div class="flex min-h-[calc(100dvh-12rem)] flex-col items-center justify-center py-16 text-center">
      <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-2xl bg-accent-purple/20">
        <svg class="h-10 w-10 text-accent-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
        </svg>
      </div>

      <h1 class="mb-4 text-5xl font-bold tracking-tight sm:text-6xl">
        <span class="gradient-text">RepoSweep</span>
      </h1>
      <p class="mx-auto mb-10 max-w-xl text-lg text-fg-muted sm:text-xl">
        Your GitHub repos, one dashboard. Toggle visibility, archive, rename, delete — no more clicking through dozens of settings pages.
      </p>

      <div class="flex flex-col items-center gap-4 sm:flex-row">
        <a
          href="/api/auth/login"
          class="inline-flex items-center gap-3 rounded-xl bg-accent-purple px-7 py-3.5 text-base font-medium text-bg-primary transition-all hover:opacity-90 hover:shadow-lg"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Sign in with GitHub
        </a>
        <a
          href="https://github.com/codywilliamson/reposweep"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-xl border border-border-default px-7 py-3.5 text-base font-medium text-fg-secondary transition-colors hover:border-accent-purple hover:text-fg-primary"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <p class="mt-8 text-xs text-fg-muted">
        Requires <code class="rounded bg-bg-tertiary px-1.5 py-0.5 font-mono text-accent-cyan">repo</code> and
        <code class="rounded bg-bg-tertiary px-1.5 py-0.5 font-mono text-accent-cyan">delete_repo</code> scopes
      </p>
    </div>

    <!-- features -->
    <section class="pb-24">
      <h2 class="mb-12 text-center text-2xl font-bold text-fg-primary sm:text-3xl">Everything you need, nothing you don't</h2>
      <div class="stagger grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="glass rounded-xl p-6">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent-purple/20">
              <svg class="h-5 w-5 text-accent-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={f.icon} />
              </svg>
            </div>
            <h3 class="mb-1 font-semibold text-fg-primary">{f.title}</h3>
            <p class="text-sm text-fg-muted">{f.description}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
