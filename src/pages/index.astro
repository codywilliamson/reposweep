---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSessionFromCookies } from "@/lib/auth";

const session = getSessionFromCookies(Astro.cookies);
if (session) return Astro.redirect("/dashboard");
---

<BaseLayout title="Sign In">
  <div class="flex min-h-[calc(100dvh-8rem)] items-center justify-center px-4">
    <div class="glass w-full max-w-md rounded-2xl p-8 text-center">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-accent-purple/20">
        <svg class="h-8 w-8 text-accent-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
        </svg>
      </div>

      <h1 class="mb-2 text-3xl font-bold gradient-text">RepoSweep</h1>
      <p class="mb-8 text-fg-muted">
        Manage your GitHub repos — toggle visibility, archive, rename, delete — all from one dashboard.
      </p>

      <a
        href="/api/auth/login"
        class="inline-flex items-center gap-3 rounded-xl bg-accent-purple px-6 py-3 text-base font-medium text-bg-primary transition-all hover:opacity-90 hover:shadow-lg"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Sign in with GitHub
      </a>

      <p class="mt-6 text-xs text-fg-muted">
        Requires <code class="rounded bg-bg-tertiary px-1.5 py-0.5 font-mono text-accent-cyan">repo</code> and
        <code class="rounded bg-bg-tertiary px-1.5 py-0.5 font-mono text-accent-cyan">delete_repo</code> scopes
      </p>
    </div>
  </div>
</BaseLayout>
