---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSessionFromCookies } from "@/lib/auth";
import { getRuntimeEnv } from "@/lib/storage";

const session = await getSessionFromCookies(Astro.cookies, getRuntimeEnv(Astro.locals));
if (session) return Astro.redirect("/dashboard");

const featureCards = [
  {
    title: "Bulk Repo Ops",
    description: "Visibility, archiving, deletion, rename, and description edits — all from one surface.",
    icon: `<path d="M4 6h16"/><path d="M4 12h10"/><path d="M4 18h7"/><path d="M17 10l3 3-3 3"/>`,
  },
  {
    title: "Commit Analytics",
    description: "Totals, velocity, weekly charts, and repo spread tuned for real active windows.",
    icon: `<path d="M3 3v18h18"/><path d="m7 13 4-4 3 3 5-7"/>`,
  },
  {
    title: "Smart Filters",
    description: "Search, narrow by visibility, archive state, language, and sort — results update instantly.",
    icon: `<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>`,
  },
  {
    title: "Transparent Coverage",
    description: "Know exactly how many repos were matched and analyzed. The numbers always have context.",
    icon: `<path d="M12 20s8-4 8-10V4l-8-2-8 2v6c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>`,
  },
  {
    title: "Color Themes",
    description: "8 built-in themes from Dracula to Solarized. Picks up your preference automatically.",
    icon: `<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>`,
  },
  {
    title: "Queue + Control",
    description: "Live operation feedback for destructive or long-running changes. Nothing feels like a black box.",
    icon: `<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 8h10"/><path d="M7 12h6"/><path d="M7 16h8"/>`,
  },
];

const stats = [
  { label: "Manage", value: "Bulk visibility, archive, delete, rename" },
  { label: "Understand", value: "Commit velocity, trendlines, spread" },
  { label: "Filter", value: "Search, sort, and slice by any dimension" },
];
---

<BaseLayout title="RepoSweep">
  <div class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-x-0 top-0 h-[38rem]">
      <div class="landing-halo landing-halo-left" />
      <div class="landing-halo landing-halo-right" />
      <div class="landing-grid absolute inset-0 opacity-50" />
    </div>

    <div class="relative mx-auto max-w-7xl px-4 pb-24 pt-10 sm:px-6">
      <section class="grid min-h-[calc(100dvh-10rem)] items-center gap-12 lg:grid-cols-[1.02fr_0.98fr]">
        <div>
          <div class="animate-in mb-6 inline-flex items-center gap-2 rounded-full border border-accent-cyan/30 bg-accent-cyan/10 px-4 py-2 text-xs font-medium uppercase tracking-[0.24em] text-accent-cyan">
            <span class="pulse-soft h-2 w-2 rounded-full bg-accent-cyan" />
            Repo Control + Commit Intelligence
          </div>

          <h1 class="animate-in animate-in-delay-1 max-w-4xl text-5xl font-bold leading-[0.95] tracking-tight sm:text-6xl xl:text-7xl">
            Sweep the chaos,
            <span class="gradient-text-animated block pt-2">see where the code is actually moving.</span>
          </h1>

          <p class="animate-in animate-in-delay-2 mt-6 max-w-2xl text-lg leading-8 text-fg-secondary sm:text-xl">
            One dashboard to wrangle a sprawling GitHub account. Bulk cleanup for repos that should've been archived
            months ago, and commit analytics that show you where the energy is actually going.
          </p>

          <div class="animate-in animate-in-delay-3 mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
            <a
              href="/api/auth/login"
              class="inline-flex items-center gap-3 rounded-2xl bg-accent-purple px-7 py-3.5 text-base font-medium text-bg-primary transition-all hover:-translate-y-0.5 hover:opacity-90 hover:shadow-[0_18px_60px_-22px_var(--ss-accent-purple)] active:translate-y-0"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Sign in with GitHub
            </a>
            <a
              href="https://github.com/codywilliamson/reposweep"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-2xl border border-border-default bg-bg-secondary/70 px-7 py-3.5 text-base font-medium text-fg-secondary transition-all hover:border-accent-purple hover:text-fg-primary active:scale-[0.98]"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              View on GitHub
            </a>
          </div>

          <div class="animate-in animate-in-delay-4 mt-8 flex flex-wrap items-center gap-3 text-sm text-fg-muted">
            <span class="rounded-full bg-bg-secondary/70 px-3 py-1.5">Commit trendlines</span>
            <span class="rounded-full bg-bg-secondary/70 px-3 py-1.5">Repo spread + filters</span>
            <span class="rounded-full bg-bg-secondary/70 px-3 py-1.5">8 color themes</span>
          </div>
        </div>

        <div class="animate-in animate-in-delay-2">
          <div class="relative mx-auto max-w-2xl">
            <div class="landing-chip landing-chip-top">
              <span class="text-xs uppercase tracking-[0.22em] text-accent-cyan">Insights</span>
              <span class="mt-1 block text-lg font-semibold text-fg-primary">Weekly commits + repo spread</span>
            </div>
            <div class="landing-chip landing-chip-bottom">
              <span class="text-xs uppercase tracking-[0.22em] text-accent-yellow">Control</span>
              <span class="mt-1 block text-lg font-semibold text-fg-primary">Bulk actions + live feedback</span>
            </div>

            <div class="glass relative overflow-hidden rounded-[2rem] border border-border-default/80 p-5 shadow-[0_30px_120px_-48px_rgba(0,0,0,0.65)]">
              <div class="absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-accent-cyan/70 to-transparent" />

              <div class="flex items-center justify-between rounded-2xl bg-bg-primary/70 px-4 py-3">
                <div>
                  <p class="text-xs uppercase tracking-[0.24em] text-fg-muted">Live Snapshot</p>
                  <p class="mt-1 text-lg font-semibold">Agent-heavy GitHub account</p>
                </div>
                <div class="flex items-center gap-1.5 rounded-full bg-accent-green/15 px-3 py-1 text-xs font-medium text-accent-green">
                  <span class="pulse-soft h-1.5 w-1.5 rounded-full bg-accent-green" />
                  synced
                </div>
              </div>

              <div class="mt-4 grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
                <div class="rounded-2xl border border-border-default bg-bg-primary/75 p-4">
                  <div class="flex items-end justify-between">
                    <div>
                      <p class="text-xs uppercase tracking-[0.22em] text-fg-muted">Commit Trend</p>
                      <p class="mt-2 text-2xl font-semibold">2,487 commits</p>
                    </div>
                    <div class="rounded-full bg-accent-green/15 px-3 py-1 text-xs font-medium text-accent-green">
                      +31% vs prior window
                    </div>
                  </div>

                  <svg viewBox="0 0 520 220" class="mt-4 h-48 w-full">
                    <defs>
                      <linearGradient id="hero-area" x1="0" x2="0" y1="0" y2="1">
                        <stop offset="0%" stop-color="var(--ss-accent-cyan)" stop-opacity="0.32" />
                        <stop offset="100%" stop-color="var(--ss-accent-purple)" stop-opacity="0.02" />
                      </linearGradient>
                    </defs>
                    <path class="chart-area-fade" d="M20 186 L20 170 L82 152 L144 160 L206 116 L268 126 L330 92 L392 58 L454 70 L500 44 L500 186 Z" fill="url(#hero-area)" />
                    <polyline
                      class="chart-draw"
                      points="20,170 82,152 144,160 206,116 268,126 330,92 392,58 454,70 500,44"
                      fill="none"
                      stroke="var(--ss-accent-purple)"
                      stroke-width="7"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <circle class="chart-area-fade" cx="392" cy="58" r="7" fill="var(--ss-accent-cyan)" />
                    <circle class="chart-area-fade" cx="500" cy="44" r="7" fill="var(--ss-accent-cyan)" />
                  </svg>

                  <div class="mt-2 flex items-center justify-between text-xs text-fg-muted">
                    <span>Jan 8</span>
                    <span>Feb 12</span>
                    <span>Mar 30</span>
                  </div>
                </div>

                <div class="space-y-4">
                  <div class="rounded-2xl border border-border-default bg-bg-primary/75 p-4">
                    <p class="text-xs uppercase tracking-[0.22em] text-fg-muted">Repo Spread</p>
                    <div class="mt-4 space-y-3">
                      {[
                        { name: "reposweep", width: "86%" },
                        { name: "agent-runner", width: "62%" },
                        { name: "prompt-lab", width: "44%" },
                      ].map((item, i) => (
                        <div>
                          <div class="mb-1 flex items-center justify-between text-sm">
                            <span>{item.name}</span>
                            <span class="text-fg-muted">{item.width}</span>
                          </div>
                          <div class="h-2 rounded-full bg-bg-secondary">
                            <div
                              class="bar-fill h-full rounded-full bg-gradient-to-r from-accent-cyan to-accent-purple"
                              style={`width:${item.width}; animation-delay: ${0.8 + i * 0.15}s;`}
                            />
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>

                  <div class="rounded-2xl border border-border-default bg-bg-primary/75 p-4">
                    <p class="text-xs uppercase tracking-[0.22em] text-fg-muted">Controls</p>
                    <div class="mt-3 flex flex-wrap gap-2">
                      <span class="rounded-full bg-accent-cyan/15 px-3 py-1 text-xs font-medium text-accent-cyan">90 days</span>
                      <span class="rounded-full bg-bg-secondary px-3 py-1 text-xs text-fg-secondary">private only</span>
                      <span class="rounded-full bg-bg-secondary px-3 py-1 text-xs text-fg-secondary">top 25 repos</span>
                      <span class="rounded-full bg-bg-secondary px-3 py-1 text-xs text-fg-secondary">sort: last 7 days</span>
                    </div>
                    <div class="mt-4 rounded-2xl bg-bg-secondary/80 p-3 text-sm text-fg-secondary">
                      Totals, weekly charts, and filters for your entire account.
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="pb-10">
        <div class="stagger grid gap-4 md:grid-cols-3">
          {stats.map((stat) => (
            <div class="glass hover-lift rounded-2xl px-5 py-5">
              <p class="text-xs uppercase tracking-[0.22em] text-fg-muted">{stat.label}</p>
              <p class="mt-3 text-xl font-semibold text-fg-primary">{stat.value}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="pb-12 pt-12">
        <div class="mb-12 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="scroll-reveal max-w-2xl">
            <p class="text-sm uppercase tracking-[0.24em] text-accent-cyan">Feature Set</p>
            <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Everything in the box when your GitHub gets loud.</h2>
          </div>
          <p class="scroll-reveal max-w-xl text-sm leading-7 text-fg-muted">
            Fast operational controls paired with analytics and context — so you can decide what to change,
            not just click the change faster.
          </p>
        </div>

        <div class="stagger grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featureCards.map((feature) => (
            <div class="glass hover-lift rounded-2xl p-6">
              <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-accent-purple/15">
                <svg class="h-5 w-5 text-accent-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={feature.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-fg-primary">{feature.title}</h3>
              <p class="mt-2 text-sm leading-7 text-fg-secondary">{feature.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="scroll-reveal pb-24 pt-12 text-center">
        <h2 class="text-3xl font-bold sm:text-4xl">Ready to get your repos under control?</h2>
        <p class="mx-auto mt-4 max-w-lg text-lg text-fg-secondary">
          Connect your GitHub, see what you're working with, and start cleaning up in under a minute.
        </p>
        <a
          href="/api/auth/login"
          class="mt-8 inline-flex items-center gap-3 rounded-2xl bg-accent-purple px-7 py-3.5 text-base font-medium text-bg-primary transition-all hover:-translate-y-0.5 hover:opacity-90 hover:shadow-[0_18px_60px_-22px_var(--ss-accent-purple)] active:translate-y-0"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Get started
        </a>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .landing-halo {
    position: absolute;
    width: 32rem;
    height: 32rem;
    border-radius: 9999px;
    filter: blur(70px);
    opacity: 0.16;
  }

  .landing-halo-left {
    left: -6rem;
    top: 1rem;
    background:
      radial-gradient(circle at 30% 30%, var(--ss-accent-cyan), transparent 58%);
  }

  .landing-halo-right {
    right: -8rem;
    top: 4rem;
    background:
      radial-gradient(circle at 50% 50%, var(--ss-accent-purple), transparent 62%);
  }

  .landing-grid {
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--ss-border-default) 40%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--ss-border-default) 40%, transparent) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.55), transparent 92%);
  }

  .landing-chip {
    position: absolute;
    z-index: 2;
    max-width: 14rem;
    border: 1px solid color-mix(in srgb, var(--ss-border-default) 72%, transparent);
    background: color-mix(in srgb, var(--ss-bg-secondary) 88%, transparent);
    backdrop-filter: blur(12px);
    border-radius: 1.25rem;
    padding: 0.9rem 1rem;
    box-shadow: 0 18px 50px -35px rgba(0, 0, 0, 0.8);
    animation: landing-float 6s ease-in-out infinite;
  }

  .landing-chip-top {
    right: -1.4rem;
    top: 2rem;
  }

  .landing-chip-bottom {
    left: -1.1rem;
    bottom: 1.75rem;
    animation-delay: -2.5s;
  }

  @keyframes landing-float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-9px);
    }
  }

  @media (max-width: 1023px) {
    .landing-chip {
      position: static;
      max-width: none;
      margin-bottom: 1rem;
      animation: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-chip {
      animation: none;
    }
  }
</style>
