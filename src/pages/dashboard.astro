---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RepoGrid from "@/components/content/RepoGrid.vue";
import { fetchUserRepos } from "@/lib/github";

const session = Astro.locals.session!;
let repos = [];
let error = "";

try {
  repos = await fetchUserRepos(session.accessToken);
} catch (e: any) {
  error = e.message ?? "Failed to fetch repositories";
}
---

<BaseLayout title="Dashboard">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold">Your Repositories</h1>
        <p class="mt-1 text-sm text-fg-muted">
          {repos.length} {repos.length === 1 ? "repository" : "repositories"} found
        </p>
      </div>
    </div>

    {error ? (
      <div class="glass rounded-xl p-8 text-center">
        <p class="text-accent-red">{error}</p>
        <a href="/api/auth/logout" class="mt-4 inline-block text-sm text-accent-cyan hover:underline">
          Sign out and try again
        </a>
      </div>
    ) : (
      <RepoGrid client:load repos={repos} login={session.login} />
    )}
  </div>
</BaseLayout>
